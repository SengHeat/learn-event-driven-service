APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:5YwytI7/+msslrgUL9pgnp89HAZ0UzgcW02VEELDsfY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=drsb_purchase_local
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

# ============================================
# REDIS
# ============================================
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PUBSUB_DB=0

# ============================================
# MESSAGING
# ============================================
#MESSAGING_DRIVER=redis    # Redis Pub/Sub
MESSAGING_DRIVER=aws      # AWS SNS + SQS
#MESSAGING_DRIVER=kafka    # Apache Kafka
#MESSAGING_DRIVER=rabbit   # RabbitMQ

# ============================================
# AWS / LOCALSTACK
# ============================================
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=ap-southeast-1
AWS_ENDPOINT=http://localhost:4566
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# SNS Topics
SNS_TOPIC_ORDER_STATUS_UPDATED=arn:aws:sns:ap-southeast-1:000000000000:order-status-updated

# SQS Queues
SQS_QUEUE_ORDER_PAYMENT_PAID=http://localhost:4566/000000000000/order-payment-paid

# ============================================
# MAIL
# ============================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# VITE
# ============================================
VITE_APP_NAME="${APP_NAME}"
